# Database connection. For docker compose the app/migrate services override this
# to use the internal "db" host; on the host machine use localhost.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/position_tracker?schema=public"

# Password required to access the app
APP_PASSWORD="changeme"

# Secret used to sign the session cookie (use a long random string in production)
AUTH_SECRET="change-me-to-a-long-random-string"

# --- Production / self-hosting behind a tunnel (see docs/deploy-raspberry-pi.md) ---

# Public hostname(s) the app is reachable at, comma-separated. Required behind a
# reverse proxy/tunnel so Next.js accepts Server Action submissions. Leave empty
# for local dev (localhost is always allowed).
ALLOWED_ORIGINS="tracker.jony.fr"

# Cloudflare Tunnel token (Zero Trust dashboard → Networks → Tunnels). Only the
# machine running the tunnel needs this; keep it secret.
TUNNEL_TOKEN=""
