# Database connection, used by host-side commands (pnpm dev, db:push, db:seed,
# db:studio) — keep it pointed at localhost for those.
#
# `docker compose up` (pnpm docker:up) ignores this: docker-compose.override.yml
# bundles its own Postgres container and wires app/migrate to it automatically,
# so local Docker runs need no DATABASE_URL at all.
#
# Production has no bundled database. The Pi deploy workflow runs with
# `-f docker-compose.yml` only (the override file never applies there) and
# requires DATABASE_URL to be set to a real Postgres connection string — supplied
# as a GitHub Actions secret (`gh secret set DATABASE_URL --body "..."`), never
# committed here. See docs/deploy-raspberry-pi.md.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/position_tracker?schema=public"

# Password required to access the app
APP_PASSWORD="changeme"

# Secret used to sign the session cookie (use a long random string in production)
AUTH_SECRET="change-me-to-a-long-random-string"

# --- Production / self-hosting behind a tunnel (see docs/deploy-raspberry-pi.md) ---
# In the Pi deployment these are NOT kept here — CI injects them from GitHub
# Actions secrets. The placeholders below just document the shape.

# Public hostname(s) the app is reachable at, comma-separated. Required behind a
# reverse proxy/tunnel so Next.js accepts Server Action submissions. Leave empty
# for local dev and before you have a domain (localhost is always allowed).
ALLOWED_ORIGINS=""

# Cloudflare Tunnel token (Zero Trust dashboard → Networks → Tunnels). Only the
# machine running the tunnel needs this; keep it secret.
TUNNEL_TOKEN=""
