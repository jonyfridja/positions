# Database connection. For docker compose the app/migrate services override this
# to use the internal "db" host; on the host machine use localhost.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/position_tracker?schema=public"

# Password required to access the app
APP_PASSWORD="changeme"

# Secret used to sign the session cookie (use a long random string in production)
AUTH_SECRET="change-me-to-a-long-random-string"
